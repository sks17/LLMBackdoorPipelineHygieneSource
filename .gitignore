# === Source-of-truth repo: tracks ALL project work (P1 + P2 + docs + plans + configs + tests). ===
# Only genuine junk, secrets, huge re-fetchable artifacts, and vendored third-party are excluded.
# Excluding from git is NOT deleting from the worktree -- everything here stays on disk.

# --- Python / caches / build / venv ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.venv/
venv/
env/
uv.lock.local
pip-wheel-metadata/

# --- Secrets -- NEVER commit (rotate the token in deploy/hyak.remote.env) ---
deploy/hyak.remote.env
*.env
!*.example.env

# --- Model / dataset caches ---
.cache/
.hf_cache/
hf_cache/

# --- Large re-fetchable binaries / scratch ---
deploy/payload.tgz
deploy/results.tgz
big.txt
test_up.txt
test_down.txt
*.faiss
*.index
*.parquet

# --- Vendored third-party (huge, re-fetchable by pinned commit; study_only/ is unlicensed) ---
HyakDocs/
docs-main/
hub-docs-main/
third_party/

# --- Generated / gated experiment data (regenerable from code+configs; curated inputs are kept) ---
data/raw/
data/synthetic/
data/shards/
data/manifests/
data/real/
data/pilot/
data/**/*.report.json

# --- Generated outputs (regenerable). Ignore everything under outputs/ EXCEPT the small P1 result
#     tables/figures; large intermediates (survival jsonl, activation .npz stores, parquet) stay out. ---
outputs/*
!outputs/analysis/
!outputs/summarization_semantic/
outputs/**/*.parquet
outputs/**/*.npz

# keep directory scaffolding + the curated canary library
!**/.gitkeep
!data/triggers/triggers.jsonl

# --- Editor / OS ---
.idea/
.vscode/
.DS_Store
Thumbs.db
